# SimpliXio Fastlane Configuration
# ---------------------------------
# Automated build + TestFlight deployment for iOS and macOS.
# Uses App Store Connect API Key for authentication (no password/2FA needed).
#
# Usage:
#   cd CortexOSApp
#   fastlane ios_testflight version:1.1.2    — build iOS + upload to TestFlight
#   fastlane mac_testflight version:1.1.2    — build macOS + upload to TestFlight
#   fastlane all_testflight version:1.1.2    — both platforms

default_platform(:ios)
require "open3"

TEAM_ID      = "2V8LZ2444Y"
IOS_BUNDLE   = "me.ph7.cortexos.ios"
MAC_BUNDLE   = "me.ph7.cortexos.macos"
WATCH_BUNDLE = "me.ph7.cortexos.watchos"
PROJECT      = "CortexOS.xcodeproj"

# App Store Connect API Key
ASC_KEY_ID   = "X45B3VFD8C"
ASC_ISSUER   = "0937aa2d-d63f-411e-928e-0ec39732c589"
ASC_KEY_PATH = File.expand_path("AuthKey_3282WM9W4R.p8", __dir__)

# Xcargs for automatic provisioning with API key
SIGN_ARGS = [
  "DEVELOPMENT_TEAM=#{TEAM_ID}",
  "CODE_SIGN_STYLE=Automatic",
  "-allowProvisioningUpdates",
  "-authenticationKeyPath #{ASC_KEY_PATH}",
  "-authenticationKeyID #{ASC_KEY_ID}",
  "-authenticationKeyIssuerID #{ASC_ISSUER}",
].join(" ")

# ── Xcode project regen ────────────────────────────────────

before_all do
  if system("which xcodegen > /dev/null 2>&1")
    sh("cd .. && xcodegen generate 2>&1")
    UI.message("Regenerated Xcode project from project.yml")
  end

  # Authenticate with App Store Connect API
  app_store_connect_api_key(
    key_id: ASC_KEY_ID,
    issuer_id: ASC_ISSUER,
    key_filepath: ASC_KEY_PATH,
    duration: 1200,
    in_house: false,
  )
end

# ── Release version helpers ────────────────────────────────

def resolve_release_version(options = {})
  value = options[:version] || ENV["VERSION_NUMBER"] || ENV["APP_VERSION"]
  value = value.to_s.strip
  value.empty? ? nil : value
end

def apply_release_version_if_requested(options = {})
  current_version = get_version_number(
    xcodeproj: PROJECT,
    target: "CortexOS-iOS",
  )
  requested_version = resolve_release_version(options)

  if requested_version.nil?
    UI.important("Using existing MARKETING_VERSION #{current_version}. Pass `version:x.y.z` when shipping a new version.")
    return current_version
  end

  unless requested_version.match?(/^\d+\.\d+\.\d+$/)
    UI.user_error!("Invalid version '#{requested_version}'. Use semantic version format x.y.z.")
  end

  if requested_version == current_version
    UI.message("MARKETING_VERSION already set to #{requested_version}.")
    return requested_version
  end

  increment_version_number(
    xcodeproj: PROJECT,
    version_number: requested_version,
  )
  UI.success("Set MARKETING_VERSION to #{requested_version}.")
  requested_version
end

def next_build_number
  Time.now.utc.strftime("%Y%m%d%H%M%S")
end

# ── iOS TestFlight ──────────────────────────────────────────

platform :ios do
  desc "Build iOS and upload to TestFlight"
  lane :testflight_release do |options|
    apply_release_version_if_requested(options)

    increment_build_number(
      xcodeproj: PROJECT,
      build_number: next_build_number,
    )

    build_app(
      project: PROJECT,
      scheme: "CortexOS-iOS",
      clean: true,
      export_method: "app-store",
      xcargs: SIGN_ARGS,
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
    )

    UI.success("iOS build uploaded to TestFlight!")
  end
end

# ── macOS TestFlight ────────────────────────────────────────

platform :mac do
  desc "Build macOS and upload to TestFlight"
  lane :testflight_release do |options|
    apply_release_version_if_requested(options)

    increment_build_number(
      xcodeproj: PROJECT,
      build_number: next_build_number,
    )

    build_app(
      project: PROJECT,
      scheme: "CortexOS-macOS",
      clean: true,
      export_method: "app-store",
      xcargs: SIGN_ARGS,
    )

    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      app_platform: "osx",
      pkg: lane_context[SharedValues::PKG_OUTPUT_PATH],
    )

    UI.success("macOS build uploaded to TestFlight!")
  end
end

# ── Convenience aliases ─────────────────────────────────────

desc "iOS TestFlight (alias)"
lane :ios_testflight do |options|
  Fastlane::LaneManager.cruise_lane("ios", "testflight_release", options)
end

desc "macOS TestFlight (alias)"
lane :mac_testflight do |options|
  Fastlane::LaneManager.cruise_lane("mac", "testflight_release", options)
end

desc "watchOS TestFlight"
lane :watch_testflight do |options|
  destinations, status = Open3.capture2e(
    "xcodebuild",
    "-showdestinations",
    "-scheme",
    "CortexOS-watchOS",
    "-project",
    PROJECT,
  )

  has_watch_destination = status.success? && destinations.include?("platform:watchOS")
  has_missing_platform_error = destinations.include?("is not installed")

  if !has_watch_destination || has_missing_platform_error
    UI.important("Skipping watchOS upload: watchOS platform is not available in this Xcode install.")
    UI.important("Install watchOS from Xcode > Settings > Components, then run `fastlane watch_testflight`.")
    next
  end

  apply_release_version_if_requested(options)

  increment_build_number(
    xcodeproj: PROJECT,
    build_number: next_build_number,
  )

  build_app(
    project: PROJECT,
    scheme: "CortexOS-watchOS",
    destination: "generic/platform=watchOS",
    clean: true,
    export_method: "app-store",
    xcargs: SIGN_ARGS,
  )

  upload_to_testflight(
    skip_waiting_for_build_processing: true,
    app_identifier: WATCH_BUNDLE,
  )

  UI.success("watchOS build uploaded to TestFlight!")
end

desc "Build and upload BOTH platforms to TestFlight"
lane :all_testflight do |options|
  Fastlane::LaneManager.cruise_lane("ios", "testflight_release", options)
  Fastlane::LaneManager.cruise_lane("mac", "testflight_release", options)
  watch_testflight(options)
end

desc "Regenerate App Store provisioning profiles (iOS app + widget)"
lane :refresh_profiles do
  sigh(
    app_identifier: IOS_BUNDLE,
    skip_install: false,
    skip_certificate_verification: true
  )

  sigh(
    app_identifier: "me.ph7.cortexos.ios.widget",
    skip_install: false,
    skip_certificate_verification: true
  )
end

desc "Generate App Store screenshot assets (iOS/macOS/watchOS)"
lane :generate_store_assets do
  sh("cd .. && ./.venv/bin/python CortexOSApp/generate_store_assets.py")
end
